import("//build/ohos.gni")
import("//build/test.gni")
import("//foundation/filemanagement/storage_service/services/storage_space_manager/storage_space_manager.gni")

ohos_fuzztest("StorageSpaceManagerFuzzTest") {
  module_out_path = "storage_service/storage_service/storage_space_manager"
  fuzz_config_file = "${storage_space_manager_path}/test/fuzztest/storagespacemanager_fuzzer"

  include_dirs = [
    "${storage_space_manager_path}/common/include",
    "${storage_space_manager_path}/interfaces/innerkits/include",
    "${storage_space_manager_path}/services/storage_space_manager/include",
  ]

  cflags = [
    "-g",
    "-O0",
    "-Wno-unused-variable",
    "-fno-omit-frame-pointer",
  ]

  sources = [
    "storage_space_manager_fuzzer.cpp",
  ]

  defines = [
    "STORAGE_SPACE_MANAGER_LOG_TAG = \"StorageSpaceManager\"",
    "LOG_DOMAIN = 0xD004302",
  ]

  deps = [
    "${storage_space_manager_path}/interfaces/innerkits:storage_space_manager_innerkits",
    "${storage_space_manager_path}/services/storage_space_manager:storage_space_manager",
  ]

  external_deps = [
    "c_utils:utils",
    "hilog:libhilog",
  ]

  subsystem_name = "filemanagement"
  part_name = "storage_service"
}

group("fuzztest") {
  testonly = true
  deps = [ ":StorageSpaceManagerFuzzTest" ]
}
