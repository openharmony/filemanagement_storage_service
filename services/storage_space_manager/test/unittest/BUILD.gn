import("//build/ohos.gni")
import("//build/test.gni")
import("//foundation/filemanagement/storage_service/services/storage_space_manager/storage_space_manager.gni")

# 本目录下 ohos_unittest 共用：聚合 innerkits IDL 公开头、子系统 config、utils/mock 等；新增用例 configs 仅填本项即可。
config("storage_space_manager_unittest_common") {
  configs = [
    "${storage_space_manager_path}/interfaces/innerkits:storage_space_manager_idl_public_config",
    "${storage_space_manager_path}/services/storage_space_manager:storage_space_manager_config",
    "${storage_space_manager_path}/common:storage_space_manager_common_include",
    "${storage_space_manager_path}/utils:storage_space_manager_utils_include",
    "${storage_space_manager_path}/test/mock:storage_space_manager_mock_include",
  ]
  defines = [
    "STORAGE_SPACE_MANAGER_LOG_TAG = \"StorageSpaceManager\"",
    "LOG_DOMAIN = 0xD004302",
  ]
  cflags = [
    "-Dprivate=public",
    "-Dprotected=public",
  ]
}

group("storage_space_manager_ut") {
  testonly = true
  deps = [
    ":cache_clean_controller_unittest",
    ":storage_space_manager_provider_unittest",
    ":storage_total_status_service_unittest",
    ":storage_common_event_subscriber_unittest",
    ":ipc_caller_auth_unittest",
    ":storage_space_manager_client_unittest",
    ":bundle_manager_connector_unittest",
    ":bundle_manager_adapter_proxy_unittest",
  ]
}

# IpcCallerAuth Unit Test (link-time mock for AccessTokenKit / IPCSkeleton)
ohos_unittest("ipc_caller_auth_unittest") {
  module_out_path = "storage_service/storage_service/storage_space_manager"

  configs = [
    ":storage_space_manager_unittest_common",
    "${storage_space_manager_path}/utils:storage_space_manager_utils_include",
  ]

  sources = [
    "ipc_caller_auth_test.cpp",
    "../../utils/src/ipc_caller_auth.cpp",
  ]

  deps = [
    "${storage_space_manager_path}/test/mock:storage_space_manager_ipc_mock_sources",
  ]

  external_deps = [
    "access_token:libaccesstoken_sdk",
    "c_utils:utils",
    "googletest:gmock_main",
    "googletest:gtest_main",
    "hilog:libhilog",
    "ipc:ipc_core",
  ]
}

