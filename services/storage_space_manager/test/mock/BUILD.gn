import("//build/ohos.gni")
import("//foundation/filemanagement/storage_service/services/storage_space_manager/storage_space_manager.gni")


config("storage_space_manager_mock_include") {
  include_dirs = [
    "${storage_space_manager_path}/test/mock",
    "${storage_space_manager_path}/test/mock/include",
  ]
}

source_set("storage_space_manager_ipc_mock_sources") {
  testonly = true
  sources = [
    "src/mock_ipc_auth_stubs.cpp",
  ]
  public_configs = [ ":storage_space_manager_mock_include" ]
  external_deps = [
    "access_token:libaccesstoken_sdk",
    "c_utils:utils",
    "ipc:ipc_core",
  ]
}

source_set("storage_space_manager_samgr_mock_sources") {
  testonly = true
  sources = [
    "src/mock_system_ability_stubs.cpp",
  ]
  public_configs = [ ":storage_space_manager_mock_include" ]
  external_deps = [
    "c_utils:utils",
    "ipc:ipc_core",
    "samgr:samgr_proxy",
  ]
}

source_set("storage_space_manager_parcel_mock_sources") {
  testonly = true
  sources = [
    "src/message_parcel_mock.cpp",
  ]
  public_configs = [ ":storage_space_manager_mock_include" ]
  external_deps = [
    "c_utils:utils",
    "googletest:gmock_main",
    "googletest:gtest_main",
    "ipc:ipc_core",
  ]
}

group("storage_space_manager_mock") {
  testonly = true
  deps = [
    ":storage_space_manager_ipc_mock_sources",
    ":storage_space_manager_samgr_mock_sources",
    ":storage_space_manager_parcel_mock_sources",
  ]
}
