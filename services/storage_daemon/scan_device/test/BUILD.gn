import("//build/test.gni")
import("//foundation/filemanagement/storage_service/storage_service_aafwk.gni")

ROOT_DIR = "${storage_daemon_path}"

ohos_unittest("scan_device_test") {
  branch_protector_ret = "pac_ret"
  sanitize = {
    integer_overflow = true
    cfi = true
    cfi_cross_dso = true
    debug = false
  }
  module_out_path = "storage_service/storage_service/storage_daemon"

  defines = [
    "STORAGE_LOG_TAG = \"StorageDaemon\"",
    "LOG_DOMAIN = 0xD004301",
    "private = public",
  ]

  include_dirs = [
    "$ROOT_DIR/scan_device/src",
    "$ROOT_DIR/include",
    "${storage_service_path}/utils/include",
    "${storage_service_common_path}/include",
  ]

  sources = [
    "$ROOT_DIR/scan_device/src/scan_device.cpp",
    "$ROOT_DIR/scan_device/test/scan_device_test.cpp",
  ]

  deps = [
    "$ROOT_DIR:storage_common_utils",
    "$ROOT_DIR:storage_daemon_header",
  ]

  external_deps = [
    "c_utils:utils",
    "googletest:gmock_main",
    "googletest:gtest_main",
    "hilog:libhilog",
  ]
}

group("storage_daemon_scan_device_test") {
  testonly = true
  deps = [
    ":scan_device_test",
  ]
}